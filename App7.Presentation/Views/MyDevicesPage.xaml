<Page
    x:Class="App7.Presentation.Views.MyDevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:vm="using:App7.Presentation.ViewModels"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    x:Name="PageRoot">

    <Page.Resources>
        <SolidColorBrush x:Key="DataGridRowHoverBackgroundBrush"                Color="#ecf3f8" />
        <SolidColorBrush x:Key="DataGridRowSelectedBackgroundBrush"             Color="Transparent" />
        <SolidColorBrush x:Key="DataGridRowSelectedHoveredBackground"           Color="#ecf3f8" />
        <SolidColorBrush x:Key="DataGridRowSelectedUnfocusedBackgroundBrush"    Color="Transparent" />
        <SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush"            Color="Transparent" />
        <SolidColorBrush x:Key="DataGridCellFocusVisualSecondaryBrush"          Color="Transparent" />
    </Page.Resources>

    <Grid Background="White">
        <ScrollViewer x:Name="MainScroller" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="ContentGrid" RowDefinitions="*,Auto">

                <Border Grid.Row="0" VerticalAlignment="Top" Margin="20,20,20,20"
                        CornerRadius="8" Background="White" BorderBrush="#E0E0E0"
                        BorderThickness="1" Translation="0,0,32">
                    <Border.Shadow><ThemeShadow /></Border.Shadow>

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">

                        <!-- Title -->
                        <TextBlock Grid.Row="0" Text="My Devices" FontSize="18" FontWeight="Bold" Padding="16,16,16,8" />

                        <!-- Controls bar -->
                        <Grid Grid.Row="1" Padding="16,0,16,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                <Button x:Name="ColumnsBtn" Content="Columns" Click="OnColumnsButtonClicked" />
                                <Button x:Name="PageSizeFilterBtn"
                                        Click="OnPageSizeFilterClicked"
                                        Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                                        Width="56" Height="32" Padding="8,0" FontSize="12">
                                    <Grid>
                                        <TextBlock x:Name="PageSizeFilterLabel" Text="10"
                                                   VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="12" />
                                        <!-- <TextBlock Text="&#xE70D;" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="10" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Right" /> -->
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Table area: border wrap → header | filter | DataGrid -->
                        <Border Grid.Row="2" Margin="16,0,16,0"
                                BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="2">
                            <Grid RowDefinitions="Auto,Auto,Auto">

                                <!-- Custom column header row -->
                                <Border Grid.Row="0" Background="#2D8A8888">
                                    <Grid x:Name="HeaderGrid" Height="40">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="ColDefName"               Width="*" MinWidth="100" />
                                            <ColumnDefinition x:Name="ColDefModelName"          Width="*" MinWidth="120" />
                                            <ColumnDefinition x:Name="ColDefIMEI"               Width="*" MinWidth="100" />
                                            <ColumnDefinition x:Name="ColDefSerialLab"          Width="*" MinWidth="80" />
                                            <ColumnDefinition x:Name="ColDefSerialNumber"       Width="*" MinWidth="80" />
                                            <ColumnDefinition x:Name="ColDefCircuitSerial"      Width="*" MinWidth="80" />
                                            <ColumnDefinition x:Name="ColDefHWVersion"          Width="*" MinWidth="70" />
                                            <ColumnDefinition x:Name="ColDefFunction"           Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Command="{x:Bind ViewModel.SortByCommand}" CommandParameter="Name"
                                                Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#4AFFFFFF"
                                                Height="40" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="8,0">
                                            <Grid>
                                                <TextBlock Text="Name" Foreground="#337f94" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <TextBlock x:Name="SortIconName" Text="&#xE70D;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="10" Opacity="0.4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                            </Grid>
                                        </Button>
                                        <Button Grid.Column="1" Command="{x:Bind ViewModel.SortByCommand}" CommandParameter="ModelName"
                                                Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#4AFFFFFF"
                                                Height="40" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="8,0">
                                            <Grid>
                                                <TextBlock Text="Model Name" Foreground="#337f94" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <TextBlock x:Name="SortIconModelName" Text="&#xE70D;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="10" Opacity="0.4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                            </Grid>
                                        </Button>
                                        <Button Grid.Column="2" Command="{x:Bind ViewModel.SortByCommand}" CommandParameter="IMEI"
                                                Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#4AFFFFFF"
                                                Height="40" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="8,0">
                                            <Grid>
                                                <TextBlock Text="IMEI" Foreground="#337f94" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <TextBlock x:Name="SortIconIMEI" Text="&#xE70D;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="10" Opacity="0.4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                            </Grid>
                                        </Button>
                                        <Button Grid.Column="3" Command="{x:Bind ViewModel.SortByCommand}" CommandParameter="SerialLab"
                                                Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#4AFFFFFF"
                                                Height="40" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="8,0">
                                            <Grid>
                                                <TextBlock Text="Serial Lab" Foreground="#337f94" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <TextBlock x:Name="SortIconSerialLab" Text="&#xE70D;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="10" Opacity="0.4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                            </Grid>
                                        </Button>
                                        <Button Grid.Column="4" Command="{x:Bind ViewModel.SortByCommand}" CommandParameter="SerialNumber"
                                                Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#4AFFFFFF"
                                                Height="40" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="8,0">
                                            <Grid>
                                                <TextBlock Text="Serial No." Foreground="#337f94" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <TextBlock x:Name="SortIconSerialNumber" Text="&#xE70D;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="10" Opacity="0.4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                            </Grid>
                                        </Button>
                                        <Button Grid.Column="5" Command="{x:Bind ViewModel.SortByCommand}" CommandParameter="CircuitSerialNumber"
                                                Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#4AFFFFFF"
                                                Height="40" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="8,0">
                                            <Grid>
                                                <TextBlock Text="Circuit Serial" Foreground="#337f94" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <TextBlock x:Name="SortIconCircuitSerial" Text="&#xE70D;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="10" Opacity="0.4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                            </Grid>
                                        </Button>
                                        <Button Grid.Column="6" Command="{x:Bind ViewModel.SortByCommand}" CommandParameter="HWVersion"
                                                Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#4AFFFFFF"
                                                Height="40" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="8,0">
                                            <Grid>
                                                <TextBlock Text="HW Version" Foreground="#337f94" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <TextBlock x:Name="SortIconHWVersion" Text="&#xE70D;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="10" Opacity="0.4" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                            </Grid>
                                        </Button>
                                        <Border Grid.Column="7" Padding="8,0" BorderThickness="0">
                                            <TextBlock Text="Function" Foreground="#337f94" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Filter row: 6 independent search TextBoxes -->
                                <Border Grid.Row="1" Background="#EEF2F3" BorderBrush="#CCCCCC" BorderThickness="0,1,0,1" Padding="0,4">
                                    <Grid x:Name="FilterGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="FilterColDefName"               Width="*" MinWidth="100" />
                                            <ColumnDefinition x:Name="FilterColDefModelName"          Width="*" MinWidth="120" />
                                            <ColumnDefinition x:Name="FilterColDefIMEI"               Width="*" MinWidth="100" />
                                            <ColumnDefinition x:Name="FilterColDefSerialLab"          Width="*" MinWidth="80" />
                                            <ColumnDefinition x:Name="FilterColDefSerialNumber"       Width="*" MinWidth="80" />
                                            <ColumnDefinition x:Name="FilterColDefCircuitSerial"      Width="*" MinWidth="80" />
                                            <ColumnDefinition x:Name="FilterColDefHWVersion"          Width="*" MinWidth="70" />
                                            <ColumnDefinition x:Name="FilterColDefFunction"           Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0" PlaceholderText="Search name…"
                                                 Text="{x:Bind ViewModel.SearchName, Mode=TwoWay}"
                                                 TextChanged="OnSearchTextChanged"
                                                 Tag="Name" Margin="4,0" FontSize="12" />
                                        <TextBox Grid.Column="1" PlaceholderText="Search model…"
                                                 Text="{x:Bind ViewModel.SearchModelName, Mode=TwoWay}"
                                                 TextChanged="OnSearchTextChanged"
                                                 Tag="ModelName" Margin="4,0" FontSize="12" />
                                        <TextBox Grid.Column="2" PlaceholderText="Search IMEI…"
                                                 Text="{x:Bind ViewModel.SearchIMEI, Mode=TwoWay}"
                                                 TextChanged="OnSearchTextChanged"
                                                 Tag="IMEI" Margin="4,0" FontSize="12" />
                                        <TextBox Grid.Column="3" PlaceholderText="Search lab…"
                                                 Text="{x:Bind ViewModel.SearchSerialLab, Mode=TwoWay}"
                                                 TextChanged="OnSearchTextChanged"
                                                 Tag="SerialLab" Margin="4,0" FontSize="12" />
                                        <TextBox Grid.Column="4" PlaceholderText="Search serial…"
                                                 Text="{x:Bind ViewModel.SearchSerialNumber, Mode=TwoWay}"
                                                 TextChanged="OnSearchTextChanged"
                                                 Tag="SerialNumber" Margin="4,0" FontSize="12" />
                                        <TextBox Grid.Column="5" PlaceholderText="Search circuit…"
                                                 Text="{x:Bind ViewModel.SearchCircuitSerial, Mode=TwoWay}"
                                                 TextChanged="OnSearchTextChanged"
                                                 Tag="CircuitSerialNumber" Margin="4,0" FontSize="12" />
                                        <TextBox Grid.Column="6" PlaceholderText="Search HW ver…"
                                                 Text="{x:Bind ViewModel.SearchHWVersion, Mode=TwoWay}"
                                                 TextChanged="OnSearchTextChanged"
                                                 Tag="HWVersion" Margin="4,0" FontSize="12" />
                                        <Button Grid.Column="7" Content="Clear Filter"
                                                Command="{x:Bind ViewModel.ClearFiltersCommand}"
                                                Style="{StaticResource AppClearFilterButtonStyle}"
                                                HorizontalAlignment="Stretch" Margin="4,0" />
                                    </Grid>
                                </Border>

                                <!-- DataGrid -->
                                <Grid Grid.Row="2">
                                <controls:DataGrid x:Name="DevicesGrid"
                                                   AutoGenerateColumns="False"
                                                   GridLinesVisibility="All"
                                                   CanUserSortColumns="False"
                                                   HeadersVisibility="None"
                                                   RowBackground="White"
                                                   AlternatingRowBackground="#F9F9F9"
                                                   ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}"
                                                   IsReadOnly="True" MinHeight="200"
                                                   BorderThickness="0"
                                                   SelectionChanged="OnGridSelectionChanged"
                                                   LayoutUpdated="OnGridLayoutUpdated">
                                    <controls:DataGrid.Columns>
                                        <controls:DataGridTextColumn Binding="{Binding Name}"               Tag="Name"               Width="*" MinWidth="100" />
                                        <controls:DataGridTextColumn Binding="{Binding ModelName}"          Tag="ModelName"          Width="*" MinWidth="120" />
                                        <controls:DataGridTextColumn Binding="{Binding IMEI}"               Tag="IMEI"               Width="*" MinWidth="100" />
                                        <controls:DataGridTextColumn Binding="{Binding SerialLab}"          Tag="SerialLab"          Width="*" MinWidth="80" />
                                        <controls:DataGridTextColumn Binding="{Binding SerialNumber}"       Tag="SerialNumber"       Width="*" MinWidth="80" />
                                        <controls:DataGridTextColumn Binding="{Binding CircuitSerialNumber}" Tag="CircuitSerialNumber" Width="*" MinWidth="80" />
                                        <controls:DataGridTextColumn Binding="{Binding HWVersion}"          Tag="HWVersion"          Width="*" MinWidth="70" />
                                        <controls:DataGridTemplateColumn Tag="Function" Width="120" IsReadOnly="True">
                                            <controls:DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Tag="{Binding}" Click="OnReturnClicked"
                                                            Style="{StaticResource AppFunctionButtonStyle}">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="&#xE8EA;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14" VerticalAlignment="Center" />
                                                            <TextBlock Text="Return" VerticalAlignment="Center" FontSize="12" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </controls:DataGridTemplateColumn.CellTemplate>
                                        </controls:DataGridTemplateColumn>
                                    </controls:DataGrid.Columns>
                                </controls:DataGrid>

                                <!-- Empty state: inside grid area -->
                                <TextBlock Text="&#xE7BA;  No matching records found"
                                           FontSize="14" Foreground="#888888"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Padding="0,40"
                                           Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}" />
                                </Grid>

                            </Grid>
                        </Border>

                        <!-- Table footer -->
                        <Grid Grid.Row="3" Background="#FAFAFA" MinHeight="56" Padding="16,0"
                              ColumnDefinitions="Auto,*,Auto"
                              Visibility="{x:Bind ViewModel.ShowingTextVisibility, Mode=OneWay}">
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="280"
                                       Text="{x:Bind ViewModel.ShowingText, Mode=OneWay}" FontSize="13" Foreground="#555555" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Content="First"    Command="{x:Bind ViewModel.FirstPageCommand}"    Style="{StaticResource AppNavButtonStyle}" />
                                <Button Content="Previous" Command="{x:Bind ViewModel.PreviousPageCommand}" Style="{StaticResource AppNavButtonStyle}" />
                                <StackPanel x:Name="PageNumbersPanel" Orientation="Horizontal" Spacing="4" />
                                <Button Content="Next" Command="{x:Bind ViewModel.NextPageCommand}" Style="{StaticResource AppNavButtonStyle}" />
                                <Button Content="Last" Command="{x:Bind ViewModel.LastPageCommand}" Style="{StaticResource AppNavButtonStyle}" />
                            </StackPanel>
                        </Grid>

                    </Grid>
                </Border>

                <!-- Footer -->
                <Border Grid.Row="1" Background="#F5F5F5" Padding="0,20,0,20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="DPI Team &#x00A9; 2026 &#xB7; Report a problem" HorizontalAlignment="Center" FontSize="12" Foreground="#777777" />
                        <Image Source="/Assets/logo.png" Height="22" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Grid Background="#60000000" Visibility="{x:Bind ViewModel.IsOverlayVisible, Mode=OneWay}">
            <ProgressRing IsActive="True" Width="48" Height="48" />
        </Grid>

        <!-- Columns popup -->
        <Grid x:Name="ColumnsOverlay" Background="#40000000"
              Visibility="{x:Bind ViewModel.ColumnsOverlayVisibility, Mode=OneWay}"
              PointerPressed="OnColumnsOverlayPressed">
            <Border x:Name="ColumnsPanel" Background="White" CornerRadius="6"
                    BorderBrush="#DDDDDD" BorderThickness="1" Padding="8"
                    MinWidth="180" HorizontalAlignment="Left" VerticalAlignment="Top">
                <ItemsControl ItemsSource="{x:Bind ViewModel.ColumnVisibilities}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ColumnVisibilityItem">
                            <CheckBox Content="{x:Bind DisplayName}" IsChecked="{x:Bind IsVisible, Mode=TwoWay}" Margin="0,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Grid>

        <!-- PageSize popup -->
        <Popup x:Name="PageSizePopup" IsLightDismissEnabled="True">
            <Border Background="White" CornerRadius="6" BorderBrush="#CCCCCC" BorderThickness="1" Width="56" Padding="8">
                <StackPanel x:Name="PageSizeListPanel" Spacing="2" />
            </Border>
        </Popup>

        <InfoBar x:Name="ReturnInfoBar" IsOpen="False" IsClosable="True" VerticalAlignment="Top" Margin="20,8,20,0" />

    </Grid>
</Page>
