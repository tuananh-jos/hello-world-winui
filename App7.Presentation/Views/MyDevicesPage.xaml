<Page
    x:Class="App7.Presentation.Views.MyDevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:vm="using:App7.Presentation.ViewModels"
    mc:Ignorable="d"
    x:Name="PageRoot">

    <Grid Background="White">

        <!-- ── Scrollable panel area ── -->
        <ScrollViewer x:Name="MainScroller" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="ContentGrid" RowDefinitions="*,Auto">

                <!-- Row 0: Panel card -->
                <Border
                    Grid.Row="0"
                    VerticalAlignment="Top"
                    Margin="20,20,20,20"
                    CornerRadius="8"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    Translation="0,0,32">
                    <Border.Shadow><ThemeShadow /></Border.Shadow>

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">

                        <!-- Title -->
                        <TextBlock Grid.Row="0" Text="Device List"
                                   FontSize="18" FontWeight="Bold" Padding="16,16,16,8" />

                        <!-- Controls bar -->
                        <Grid Grid.Row="1" Padding="16,0,16,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                <Button x:Name="ColumnsBtn" Content="Columns" Click="OnColumnsButtonClicked" />
                                <ComboBox PlaceholderText="Rows"
                                          ItemsSource="{x:Bind ViewModel.PageSizeOptions}"
                                          SelectedItem="{x:Bind ViewModel.SelectedPageSize, Mode=TwoWay}"
                                          MinWidth="90" />
                            </StackPanel>
                        </Grid>

                        <!-- Search + DataGrid -->
                        <Grid Grid.Row="2" RowDefinitions="Auto,*">

                            <!-- Search bar -->
                            <Grid Grid.Row="0" Padding="16,0,16,8" ColumnDefinitions="*,Auto,Auto,Auto">
                                <TextBox Grid.Column="0"
                                         PlaceholderText="Search by name, IMEI, serial…"
                                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,8,0" />
                                <ComboBox Grid.Column="1" PlaceholderText="HW Version"
                                          ItemsSource="{x:Bind ViewModel.HWVersions, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedHWVersion, Mode=TwoWay}"
                                          MinWidth="130" Margin="0,0,8,0" />
                                <Button Grid.Column="2" Content="Search"
                                        Command="{x:Bind ViewModel.ApplyFiltersCommand}"
                                        Style="{ThemeResource AccentButtonStyle}" Margin="0,0,8,0" />
                                <Button Grid.Column="3" Content="Clear"
                                        Command="{x:Bind ViewModel.ClearFiltersCommand}" />
                            </Grid>

                            <!-- Initial ProgressBar -->
                            <ProgressBar Grid.Row="0" x:Name="InitialLoadBar"
                                         IsIndeterminate="True" VerticalAlignment="Bottom"
                                         Visibility="{x:Bind ViewModel.InitialLoadingVisibility, Mode=OneWay}" />

                            <!-- DataGrid -->
                            <controls:DataGrid Grid.Row="1" x:Name="DevicesGrid"
                                               AutoGenerateColumns="False"
                                               GridLinesVisibility="Horizontal"
                                               CanUserSortColumns="True"
                                               Sorting="OnSorting"
                                               ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}"
                                               IsReadOnly="True" MinHeight="200">
                                <controls:DataGrid.Resources>
                                    <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
                                </controls:DataGrid.Resources>
                                <controls:DataGrid.Columns>
                                    <controls:DataGridTextColumn Header="Name"           Binding="{Binding Name}"               Tag="Name"               MinWidth="180" />
                                    <controls:DataGridTextColumn Header="IMEI"           Binding="{Binding IMEI}"               Tag="IMEI"               MinWidth="160" />
                                    <controls:DataGridTextColumn Header="Serial Lab"     Binding="{Binding SerialLab}"          Tag="SerialLab"          MinWidth="130" />
                                    <controls:DataGridTextColumn Header="Serial No."     Binding="{Binding SerialNumber}"       Tag="SerialNumber"       MinWidth="130" />
                                    <controls:DataGridTextColumn Header="Circuit Serial" Binding="{Binding CircuitSerialNumber}" Tag="CircuitSerialNumber" MinWidth="130" />
                                    <controls:DataGridTextColumn Header="HW Version"     Binding="{Binding HWVersion}"          Tag="HWVersion"          MinWidth="110" />
                                    <controls:DataGridTemplateColumn Header="" MinWidth="90" IsReadOnly="True" CanUserSort="False">
                                        <controls:DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Return" Tag="{Binding}"
                                                        Style="{StaticResource AppCancelButtonStyle}"
                                                        Padding="10,4" Margin="4,0"
                                                        Click="OnReturnClicked" />
                                            </DataTemplate>
                                        </controls:DataGridTemplateColumn.CellTemplate>
                                    </controls:DataGridTemplateColumn>
                                </controls:DataGrid.Columns>
                            </controls:DataGrid>
                        </Grid>

                        <!-- Pagination row -->
                        <Grid Grid.Row="3" Background="#FAFAFA" MinHeight="80"
                              Padding="16,0" ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                       TextWrapping="Wrap" MaxWidth="280"
                                       Text="{x:Bind ViewModel.ShowingText, Mode=OneWay}"
                                       FontSize="13" Foreground="#555555" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        Spacing="4" VerticalAlignment="Center">
                                <Button Content="First"    Command="{x:Bind ViewModel.FirstPageCommand}"    Style="{StaticResource AppNavButtonStyle}" />
                                <Button Content="Previous" Command="{x:Bind ViewModel.PreviousPageCommand}" Style="{StaticResource AppNavButtonStyle}" />
                                <StackPanel x:Name="PageNumbersPanel" Orientation="Horizontal" Spacing="4" />
                                <Button Content="Next" Command="{x:Bind ViewModel.NextPageCommand}" Style="{StaticResource AppNavButtonStyle}" />
                                <Button Content="Last" Command="{x:Bind ViewModel.LastPageCommand}" Style="{StaticResource AppNavButtonStyle}" />
                            </StackPanel>
                        </Grid>

                    </Grid>
                </Border>

                <!-- Row 1: Footer (sticks to bottom when content is short) -->
                <Border Grid.Row="1" Background="#F5F5F5" Padding="0,20,0,20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="DPI Team &#x00A9; 2026 &#xB7; Report a problem"
                                   HorizontalAlignment="Center" FontSize="12" Foreground="#777777" />
                        <Image Source="/Assets/logo.png" Height="22" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>


        <!-- Loading overlay -->
        <Grid Background="#60000000"
              Visibility="{x:Bind ViewModel.IsOverlayVisible, Mode=OneWay}">
            <ProgressRing IsActive="True" Width="48" Height="48" />
        </Grid>

        <!-- Columns popup overlay -->
        <Grid x:Name="ColumnsOverlay" Background="#40000000"
              Visibility="{x:Bind ViewModel.ColumnsOverlayVisibility, Mode=OneWay}"
              PointerPressed="OnColumnsOverlayPressed">
            <Border x:Name="ColumnsPanel" Background="White" CornerRadius="6"
                    BorderBrush="#DDDDDD" BorderThickness="1" Padding="8"
                    MinWidth="180" HorizontalAlignment="Left" VerticalAlignment="Top">
                <ItemsControl ItemsSource="{x:Bind ViewModel.ColumnVisibilities}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ColumnVisibilityItem">
                            <CheckBox Content="{x:Bind DisplayName}"
                                      IsChecked="{x:Bind IsVisible, Mode=TwoWay}" Margin="0,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Grid>

        <!-- InfoBar -->
        <InfoBar Grid.Row="0" x:Name="ReturnInfoBar" IsOpen="False" IsClosable="True"
                 VerticalAlignment="Top" Margin="20,8,20,0" />

    </Grid>
</Page>
