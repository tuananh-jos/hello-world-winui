<Page
    x:Class="App7.Presentation.Views.MyDevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:App7.Presentation.ViewModels"
    xmlns:constants="using:App7.Domain.Constants"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:localc="using:App7.Presentation.Controls"
    x:Name="PageRoot">

    <Page.Resources>
        <SolidColorBrush x:Key="DataGridRowHoverBackgroundBrush"                Color="#ecf3f8" />
        <SolidColorBrush x:Key="DataGridRowSelectedBackgroundBrush"             Color="Transparent" />
        <SolidColorBrush x:Key="DataGridRowSelectedHoveredBackground"           Color="#ecf3f8" />
        <SolidColorBrush x:Key="DataGridRowSelectedUnfocusedBackgroundBrush"    Color="Transparent" />
        <SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush"            Color="Transparent" />
        <SolidColorBrush x:Key="DataGridCellFocusVisualSecondaryBrush"          Color="Transparent" />
    </Page.Resources>

    <localc:PageLayoutTemplate Title="My Devices" ViewModel="{x:Bind ViewModel, Mode=OneWay}" TableMinWidth="1000">
        <localc:PageLayoutTemplate.TableContent>
            <Grid RowDefinitions="Auto,Auto,Auto">

                <localc:SmartDataTable Grid.Row="0" Grid.RowSpan="3"
                                      ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                                      EmptyVisibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}"
                                      SortCommand="{x:Bind ViewModel.SortByCommand, Mode=OneWay}"
                                      ClearFiltersCommand="{x:Bind ViewModel.ClearFiltersCommand, Mode=OneWay}"
                                      SortColumn="{x:Bind ViewModel.SortColumn, Mode=OneWay}"
                                      SortAscending="{x:Bind ViewModel.SortAscending, Mode=OneWay}"
                                      x:Name="DevicesTable">

                    <localc:SmartColumn Header="{x:Bind constants:ColumnTags.NAME_LABEL}" 
                                       Tag="{x:Bind constants:ColumnTags.NAME}" 
                                       BindingPath="Name" 
                                       MinWidth="120"
                                       FilterType="Text" 
                                       FilterPlaceholder="Search name…"
                                       SearchText="{x:Bind ViewModel.SearchName, Mode=TwoWay}" />

                    <localc:SmartColumn Header="{x:Bind constants:ColumnTags.MODEL_NAME_LABEL}" 
                                       Tag="{x:Bind constants:ColumnTags.MODEL_NAME}" 
                                       BindingPath="ModelName" 
                                       MinWidth="120"
                                       FilterType="Text" 
                                       FilterPlaceholder="Search model…"
                                       SearchText="{x:Bind ViewModel.SearchModelName, Mode=TwoWay}" />

                    <localc:SmartColumn Header="{x:Bind constants:ColumnTags.IMEI_LABEL}" 
                                       Tag="{x:Bind constants:ColumnTags.IMEI}" 
                                       BindingPath="IMEI" 
                                       MinWidth="150"
                                       FilterType="Text" 
                                       FilterPlaceholder="Search IMEI…"
                                       SearchText="{x:Bind ViewModel.SearchIMEI, Mode=TwoWay}" />

                    <localc:SmartColumn Header="{x:Bind constants:ColumnTags.SERIAL_LAB_LABEL}" 
                                       Tag="{x:Bind constants:ColumnTags.SERIAL_LAB}" 
                                       BindingPath="SerialLab" 
                                       MinWidth="130"
                                       FilterType="Text" 
                                       FilterPlaceholder="Search lab…"
                                       SearchText="{x:Bind ViewModel.SearchSerialLab, Mode=TwoWay}" />

                    <localc:SmartColumn Header="{x:Bind constants:ColumnTags.SERIAL_NUMBER_LABEL}" 
                                       Tag="{x:Bind constants:ColumnTags.SERIAL_NUMBER}" 
                                       BindingPath="SerialNumber" 
                                       MinWidth="130"
                                       FilterType="Text" 
                                       FilterPlaceholder="Search serial…"
                                       SearchText="{x:Bind ViewModel.SearchSerialNumber, Mode=TwoWay}" />

                    <localc:SmartColumn Header="{x:Bind constants:ColumnTags.CIRCUIT_SERIAL_NUMBER_LABEL}" 
                                       Tag="{x:Bind constants:ColumnTags.CIRCUIT_SERIAL_NUMBER}" 
                                       BindingPath="CircuitSerialNumber" 
                                       MinWidth="130"
                                       FilterType="Text" 
                                       FilterPlaceholder="Search circuit…"
                                       SearchText="{x:Bind ViewModel.SearchCircuitSerial, Mode=TwoWay}" />

                    <localc:SmartColumn Header="{x:Bind constants:ColumnTags.HW_VERSION_LABEL}" 
                                       Tag="{x:Bind constants:ColumnTags.HW_VERSION}" 
                                       BindingPath="HWVersion" 
                                       MinWidth="70"
                                       FilterType="Text" 
                                       FilterPlaceholder="Search HW ver…"
                                       SearchText="{x:Bind ViewModel.SearchHWVersion, Mode=TwoWay}" />

                    <localc:SmartColumn Header="Function" 
                                       Tag="{x:Bind constants:ColumnTags.FUNCTION}" 
                                       MinWidth="100" Width="120"
                                       IsSortable="False"
                                       FilterType="ClearButton">
                        <localc:SmartColumn.CellTemplate>
                            <DataTemplate>
                                <Button Tag="{Binding}" Click="OnReturnClicked"
                                        Style="{StaticResource AppFunctionButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="&#xE8EA;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14" VerticalAlignment="Center" />
                                        <TextBlock Text="Return" VerticalAlignment="Center" FontSize="12" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </localc:SmartColumn.CellTemplate>
                    </localc:SmartColumn>
                </localc:SmartDataTable>
            </Grid>
        </localc:PageLayoutTemplate.TableContent>

        <localc:PageLayoutTemplate.Overlays>
            <Grid>
                <InfoBar x:Name="ReturnInfoBar" IsOpen="False" IsClosable="True" VerticalAlignment="Top" Margin="20,8,20,0" />
            </Grid>
        </localc:PageLayoutTemplate.Overlays>
    </localc:PageLayoutTemplate>
</Page>
