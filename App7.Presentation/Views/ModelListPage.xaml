<Page
    x:Class="App7.Presentation.Views.ModelListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="0,8,0,0">

        <!-- ── Toolbar: Search + Filters + Buttons ── -->
        <Grid Grid.Row="0" Padding="0,0,0,8" ColumnDefinitions="*,Auto,Auto,Auto">

            <TextBox
                Grid.Column="0"
                PlaceholderText="Search by name or manufacturer…"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Margin="0,0,8,0" />

            <ComboBox
                Grid.Column="1"
                PlaceholderText="Category"
                ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                MinWidth="140"
                Margin="0,0,8,0" />

            <ComboBox
                Grid.Column="2"
                PlaceholderText="SubCategory"
                ItemsSource="{x:Bind ViewModel.SubCategories, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedSubCategory, Mode=TwoWay}"
                MinWidth="140"
                Margin="0,0,8,0" />

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                <Button
                    Content="Search"
                    Command="{x:Bind ViewModel.ApplyFiltersCommand}"
                    Style="{ThemeResource AccentButtonStyle}" />
                <Button
                    Content="Clear"
                    Command="{x:Bind ViewModel.ClearFiltersCommand}" />
            </StackPanel>
        </Grid>

        <!-- ── Loading indicator ── -->
        <ProgressBar
            Grid.Row="1"
            x:Name="LoadingBar"
            IsIndeterminate="True"
            x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <!-- ── Data Grid ── -->
        <controls:DataGrid
            Grid.Row="2"
            AutoGenerateColumns="False"
            GridLinesVisibility="Horizontal"
            CanUserSortColumns="True"
            Sorting="OnSorting"
            ItemsSource="{x:Bind ViewModel.Models, Mode=OneWay}"
            IsReadOnly="True">

            <controls:DataGrid.Resources>
                <SolidColorBrush x:Key="DataGridColumnHeaderBackgroundColor" Color="Transparent" />
            </controls:DataGrid.Resources>

            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="Name"        Binding="{Binding Name}"         Tag="Name"         MinWidth="180" />
                <controls:DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Tag="Manufacturer" MinWidth="150" />
                <controls:DataGridTextColumn Header="Category"    Binding="{Binding Category}"     Tag="Category"     MinWidth="130" />
                <controls:DataGridTextColumn Header="SubCategory" Binding="{Binding SubCategory}"  Tag="SubCategory"  MinWidth="130" />
                <controls:DataGridTextColumn Header="Available"   Binding="{Binding Available}"    Tag="Available"    MinWidth="100" />
                <controls:DataGridTemplateColumn Header="" MinWidth="90" IsReadOnly="True" CanUserSort="False">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button
                                Content="Borrow"
                                Tag="{Binding}"
                                Style="{StaticResource AppOkButtonStyle}"
                                Padding="10,4"
                                Margin="4,0"
                                Click="OnBorrowClicked" />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- ── Pagination bar ── -->
        <Grid Grid.Row="3" Padding="0,8,0,0" ColumnDefinitions="Auto,*,Auto">

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{x:Bind ViewModel.TotalCountText, Mode=OneWay}" />

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8"
                VerticalAlignment="Center">
                <Button Content="◀ Prev" Command="{x:Bind ViewModel.PreviousPageCommand}" />
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Page " />
                    <Run Text="{x:Bind ViewModel.CurrentPage, Mode=OneWay}" />
                    <Run Text=" of " />
                    <Run Text="{x:Bind ViewModel.TotalPages, Mode=OneWay}" />
                </TextBlock>
                <Button Content="Next ▶" Command="{x:Bind ViewModel.NextPageCommand}" />
            </StackPanel>
        </Grid>

    </Grid>
</Page>
