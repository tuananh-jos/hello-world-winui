<Page
    x:Class="App7.Presentation.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:localc="using:App7.Presentation.Controls"
    mc:Ignorable="d"
    Loaded="OnLoaded">

    <!--
        Row 0 (48px) — AppTitleBar: thin strip with app name, aligned with min/max/close.
                        This is designated as the custom title bar drag area.
        Row 1 (56px) — Header bar: hamburger + logo (image background).
        Row 2 (*)    — SplitView: sidebar + Frame.
    -->
    <Grid RowDefinitions="48,56,*">

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0 — TITLE BAR STRIP
             Designated as the drag region via SetTitleBar(AppTitleBar).
             IsHitTestVisible keeps the strip interactive for dragging,
             but nothing inside needs to be clickable.
             ═══════════════════════════════════════════════════════════ -->
        <Grid
            Grid.Row="0"
            x:Name="AppTitleBar"
            IsHitTestVisible="True"
            Background="Transparent">

            <TextBlock
                x:Name="AppTitleBarText"
                VerticalAlignment="Center"
                Margin="12,0,0,0"
                Style="{StaticResource CaptionTextBlockStyle}" />
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1 — HEADER BAR (hamburger + logo)
             NOT part of the title bar → clicks work normally.
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.Background>
                <ImageBrush
                    ImageSource="/Assets/header-bg.png"
                    Stretch="UniformToFill" />
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />   <!-- hamburger -->
                <ColumnDefinition Width="200" />    <!-- logo zone (~sidebar width) -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ☰ Hamburger — flush left, no hover effect -->
            <localc:HandButton
                Grid.Column="0"
                x:Name="HamburgerBtn"
                Command="{x:Bind ViewModel.ToggleSidebarCommand}"
                Background="Transparent"
                BorderThickness="0"
                Foreground="White"
                FontSize="18"
                Width="48"
                Height="56"
                Content="&#xE700;"
                FontFamily="{StaticResource SymbolThemeFontFamily}"
                VerticalAlignment="Center">
                <localc:HandButton.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </localc:HandButton.Template>
            </localc:HandButton>

            <!-- Logo — centred in sidebar-width zone -->
            <Image
                Grid.Column="1"
                Source="/Assets/logo.png"
                Height="36"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2 — SPLITVIEW
             ═══════════════════════════════════════════════════════════ -->
        <SplitView
            Grid.Row="2"
            x:Name="MainSplitView"
            DisplayMode="Inline"
            OpenPaneLength="200"
            IsPaneOpen="{x:Bind ViewModel.IsSidebarOpen, Mode=TwoWay}"
            PanePlacement="Left">

            <!-- ─── SIDEBAR PANE ──────────────────────────────────── -->
            <SplitView.Pane>
                <Grid
                    Background="{StaticResource AppSidebarBrush}"
                    RowDefinitions="Auto,*">

                    <!-- Sidebar header -->
                    <Border
                        Grid.Row="0"
                        Background="{StaticResource AppSidebarHeaderBrush}"
                        Padding="16,12">
                        <TextBlock
                            Text="Device Management"
                            Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold" />
                    </Border>

                    <!-- Nav items -->
                    <StackPanel Grid.Row="1">

                        <localc:HandButton
                            x:Name="NavRequestDevice"
                            Content="Request Device"
                            Command="{x:Bind ViewModel.NavigateToModelsCommand}"
                            Height="44"
                            Padding="16,0"
                            Style="{StaticResource AppSidebarItemStyle}"
                            Background="{x:Bind NavModelsBg, Mode=OneWay}" />

                        <localc:HandButton
                            x:Name="NavMyDevice"
                            Content="My Device"
                            Command="{x:Bind ViewModel.NavigateToMyDevicesCommand}"
                            Height="44"
                            Padding="16,0"
                            Style="{StaticResource AppSidebarItemStyle}"
                            Background="{x:Bind NavMyDevicesBg, Mode=OneWay}" />

                    </StackPanel>
                </Grid>
            </SplitView.Pane>

            <!-- ─── CONTENT FRAME ─────────────────────────────────── -->
            <Frame x:Name="NavigationFrame" />

        </SplitView>
    </Grid>
</Page>
