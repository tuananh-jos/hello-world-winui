<UserControl
    x:Class="App7.Presentation.Controls.ColumnVisibilityPicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:App7.Presentation.ViewModels">


    <Button Content="Columns">
        <Button.Flyout>
            <Flyout Placement="BottomEdgeAlignedRight" LightDismissOverlayMode="On">
                <Flyout.FlyoutPresenterStyle>
                    <Style TargetType="FlyoutPresenter">
                        <Setter Property="Padding" Value="8"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="CornerRadius" Value="6"/>
                        <Setter Property="BorderBrush" Value="#DDDDDD"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="MinWidth" Value="180"/>
                    </Style>
                </Flyout.FlyoutPresenterStyle>
                <ItemsControl ItemsSource="{x:Bind ViewModel.ColumnVisibilities, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ColumnVisibilityItem">
                            <CheckBox Content="{x:Bind DisplayName}" IsChecked="{x:Bind IsVisible, Mode=TwoWay}" Margin="0,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Flyout>
        </Button.Flyout>
    </Button>
</UserControl>
