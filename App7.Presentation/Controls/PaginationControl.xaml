<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="App7.Presentation.Controls.PaginationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:App7.Presentation.ViewModels"
    x:Name="Root">

    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
        <Button Content="First"    Command="{x:Bind ViewModel.FirstPageCommand, Mode=OneWay}"    Style="{StaticResource AppNavButtonStyle}" />
        <Button Content="Previous" Command="{x:Bind ViewModel.PreviousPageCommand, Mode=OneWay}" Style="{StaticResource AppNavButtonStyle}" />
        
        <StackPanel x:Name="PageNumbersPanel" Orientation="Horizontal" Spacing="4" />
        
        <Button Content="Next"     Command="{x:Bind ViewModel.NextPageCommand, Mode=OneWay}" Style="{StaticResource AppNavButtonStyle}" />
        <Button Content="Last"     Command="{x:Bind ViewModel.LastPageCommand, Mode=OneWay}" Style="{StaticResource AppNavButtonStyle}" />
    </StackPanel>
</UserControl>
