<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ╔══════════════════════════════════════════════════════════════╗
        ║  APP THEME BRUSHES — Edit here to retheme the entire app    ║
        ╚══════════════════════════════════════════════════════════════╝

        Primary navy  : used for: dialog header, NavigationView pane,
                        column headers, accent surfaces.
        Cancel orange : destructive / cancel action button.
        OK blue       : confirm / primary action button.
    -->

    <!-- ── Raw colours (don't reference these directly in UI) ────── -->
    <Color x:Key="RawNavy">#1E3D6B</Color>
    <Color x:Key="RawNavyDark">#152D52</Color>
    <Color x:Key="RawOrange">#D95F0A</Color>
    <Color x:Key="RawOrangeHover">#C0530A</Color>
    <Color x:Key="RawBlue">#0078D4</Color>
    <Color x:Key="RawBlueHover">#006CBE</Color>
    <Color x:Key="RawSidebar">#566b7f</Color>
    <Color x:Key="RawSidebarHeader">#3f5061</Color>
    <Color x:Key="RawSidebarSelected">#4a5f72</Color>
    <Color x:Key="RawSidebarHover">#60798d</Color>

    <!-- ── Semantic brushes (reference these in UI) ──────────────── -->

    <!-- Navigation / shell chrome -->
    <SolidColorBrush x:Key="AppNavyBrush"         Color="{StaticResource RawNavy}" />
    <SolidColorBrush x:Key="AppNavyDarkBrush"     Color="{StaticResource RawNavyDark}" />

    <!-- Dialog header -->
    <SolidColorBrush x:Key="AppDialogHeaderBrush" Color="{StaticResource RawNavy}" />

    <!-- Action buttons -->
    <SolidColorBrush x:Key="AppCancelBrush"       Color="{StaticResource RawOrange}" />
    <SolidColorBrush x:Key="AppCancelHoverBrush"  Color="{StaticResource RawOrangeHover}" />
    <SolidColorBrush x:Key="AppOkBrush"           Color="{StaticResource RawBlue}" />
    <SolidColorBrush x:Key="AppOkHoverBrush"      Color="{StaticResource RawBlueHover}" />

    <!-- Text on coloured backgrounds -->
    <SolidColorBrush x:Key="AppOnNavyBrush"       Color="White" />
    <SolidColorBrush x:Key="AppOnActionBrush"     Color="White" />

    <!-- Dialog body surface -->
    <SolidColorBrush x:Key="AppDialogBodyBrush"   Color="White" />

    <!-- Disabled field background -->
    <SolidColorBrush x:Key="AppDisabledFieldBrush" Color="#F3F3F3" />

    <!-- Sidebar -->
    <SolidColorBrush x:Key="AppSidebarBrush"         Color="{StaticResource RawSidebar}" />
    <SolidColorBrush x:Key="AppSidebarHeaderBrush"   Color="{StaticResource RawSidebarHeader}" />
    <SolidColorBrush x:Key="AppSidebarSelectedBrush" Color="{StaticResource RawSidebarSelected}" />
    <SolidColorBrush x:Key="AppSidebarHoverBrush"    Color="{StaticResource RawSidebarHover}" />

    <!--
        ┌─────────────────────────────────────────────────────────────┐
        │  Button Styles                                              │
        └─────────────────────────────────────────────────────────────┘
    -->

    <!-- Cancel button style (white text on orange) -->
    <Style x:Key="AppCancelButtonStyle" TargetType="Button">
        <Setter Property="Background"          Value="{StaticResource AppCancelBrush}" />
        <Setter Property="Foreground"          Value="{StaticResource AppOnActionBrush}" />
        <Setter Property="BorderThickness"     Value="0" />
        <Setter Property="Padding"             Value="20,8" />
        <Setter Property="CornerRadius"        Value="4" />
        <Setter Property="FontWeight"          Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{StaticResource AppCancelHoverBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{StaticResource AppCancelHoverBrush}" />
                                        <Setter Target="Root.Opacity" Value="0.8" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{TemplateBinding Foreground}"
                            FontWeight="{TemplateBinding FontWeight}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- OK button style (white text on blue) -->
    <Style x:Key="AppOkButtonStyle" TargetType="Button">
        <Setter Property="Background"          Value="{StaticResource AppOkBrush}" />
        <Setter Property="Foreground"          Value="{StaticResource AppOnActionBrush}" />
        <Setter Property="BorderThickness"     Value="0" />
        <Setter Property="Padding"             Value="20,8" />
        <Setter Property="CornerRadius"        Value="4" />
        <Setter Property="FontWeight"          Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{StaticResource AppOkHoverBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="{StaticResource AppOkHoverBrush}" />
                                        <Setter Target="Root.Opacity" Value="0.8" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{TemplateBinding Foreground}"
                            FontWeight="{TemplateBinding FontWeight}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar nav item button style -->
    <Style x:Key="AppSidebarItemStyle" TargetType="Button">
        <Setter Property="Background"              Value="Transparent" />
        <Setter Property="Foreground"              Value="White" />
        <Setter Property="BorderThickness"         Value="0" />
        <Setter Property="CornerRadius"            Value="0" />
        <Setter Property="HorizontalAlignment"     Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="UseSystemFocusVisuals"   Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}"
                        Height="{TemplateBinding Height}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background"
                                                Value="{StaticResource AppSidebarHoverBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.7" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center"
                            Foreground="{TemplateBinding Foreground}"
                            FontSize="{TemplateBinding FontSize}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- First / Prev / Next / Last pill button -->
    <Style x:Key="AppNavButtonStyle" TargetType="Button">
        <Setter Property="Background"          Value="White" />
        <Setter Property="Foreground"          Value="#333333" />
        <Setter Property="BorderBrush"         Value="#DDDDDD" />
        <Setter Property="BorderThickness"     Value="1" />
        <Setter Property="Padding"             Value="14,6" />
        <Setter Property="CornerRadius"        Value="20" />
        <Setter Property="FontSize"            Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="#F0F0F0" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.4" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontSize="{TemplateBinding FontSize}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Borrow / Return function button: #54b07d text, hover swap -->
    <Style x:Key="AppFunctionButtonStyle" TargetType="Button">
        <Setter Property="Background"          Value="Transparent" />
        <Setter Property="Foreground"          Value="#54b07d" />
        <Setter Property="BorderThickness"     Value="0" />
        <Setter Property="Padding"             Value="8,4" />
        <Setter Property="CornerRadius"        Value="4" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="#54b07d" />
                                        <Setter Target="Content.Foreground" Value="White" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="#3d8f61" />
                                        <Setter Target="Content.Foreground" Value="White" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Opacity" Value="0.35" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Clear Filter button: #429cb6 text, hover swap -->
    <Style x:Key="AppClearFilterButtonStyle" TargetType="Button">
        <Setter Property="Background"          Value="Transparent" />
        <Setter Property="Foreground"          Value="#429cb6" />
        <Setter Property="BorderThickness"     Value="0" />
        <Setter Property="Padding"             Value="8,4" />
        <Setter Property="CornerRadius"        Value="4" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="FontSize"            Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="#429cb6" />
                                        <Setter Target="Content.Foreground" Value="White" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="Root.Background" Value="#2f7a91" />
                                        <Setter Target="Content.Foreground" Value="White" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontSize="{TemplateBinding FontSize}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
